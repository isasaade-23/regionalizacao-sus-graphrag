# Copie para .env e preencha. O .env NAO e versionado.

# --- LLM (Google Gemini) usado como professor na destilacao e no Text2Cypher via API ---
# Aceita uma ou varias chaves separadas por virgula (rotacao para respeitar rate limit).
GEMINI_API_KEYS=chave1,chave2

# Modelo do Gemini para geracao de Cypher e do dataset sintetico
GEMINI_MODEL=gemini-2.0-flash

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=troque_esta_senha

# --- Modelo fine-tunado (opcional; servido localmente apos o QLoRA) ---
# base do HF e caminho do adapter LoRA gerado no notebook do Kaggle
MODELO_BASE=Qwen/Qwen2.5-1.5B-Instruct
ADAPTER_DIR=adapters/text2cypher-sus
