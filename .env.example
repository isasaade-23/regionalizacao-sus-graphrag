# Copie para .env e preencha. O .env NAO e versionado (ver .gitignore).

# ─────────────────────────────────────────────
# LLM — Google Gemini (professor da destilacao e baseline de API)
# Uma chave por variavel numerada. O cliente faz rotacao round-robin entre elas
# para respeitar o rate limit do free tier (mesmo padrao do pipeline AMR/EMERALD).
# ─────────────────────────────────────────────
GEMINI_KEY_1=cole_sua_chave_aqui
GEMINI_KEY_2=
GEMINI_KEY_3=
# ... adicione GEMINI_KEY_4, _5, ... conforme precisar

# Modelo primario + fallbacks (rotaciona no retry)
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# LLM — Groq (baseline de API alternativo; grátis, serve modelos abertos fortes)
# Opcional. Se preenchido, habilita --provider groq no text2cypher.
# ─────────────────────────────────────────────
GROQ_KEY_1=
GROQ_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Neo4j
# ─────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=troque_esta_senha

# ─────────────────────────────────────────────
# Modelo fine-tunado (servido localmente apos o QLoRA)
# ─────────────────────────────────────────────
MODELO_BASE=Qwen/Qwen2.5-1.5B-Instruct
ADAPTER_DIR=adapters/text2cypher-sus
